[project]
name = "{{ project_name }}"
goal = "{{ goal }}"

[loki]
# Grafana Cloud Loki push endpoint
# Set via environment: GENCTL_LOKI_URL
endpoint = ""
# Set via environment: GENCTL_LOKI_USER
user = ""
# Set via environment: GENCTL_LOKI_TOKEN
token = ""

[issues]
# Backend: "github" or "linear"
backend = "github"

[a2h]
# A2H gateway endpoint
# Set via environment: GENCTL_A2H_GATEWAY_URL
gateway_url = ""
{% if target_repos %}

[targets]
repos = [
{%- for repo in target_repos %}
    "{{ repo }}",
{%- endfor %}
]
{% endif %}
